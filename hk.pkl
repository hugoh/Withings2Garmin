amends "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    // Generic hygiene
    ["conflicts"] = Builtins.check_merge_conflict
    ["trailing-ws"] = Builtins.trailing_whitespace
    ["line-endings"] = Builtins.mixed_line_ending
    ["newlines"] = Builtins.newlines
    ["case-conflict"] = Builtins.check_case_conflict
    ["large-files"] = Builtins.check_added_large_files
    ["executables"] = Builtins.check_executables_have_shebangs
    // false positives allowlisted via .gitleaksignore (gitleaks' own
    // mechanism - `gitleaks dir` scans the whole tree regardless of which
    // files hk passes it, so a step-level `exclude` here wouldn't work)
    ["gitleaks"] = Builtins.gitleaks
    ["typos"] = Builtins.typos

    // GitHub Actions workflows
    ["actionlint"] = Builtins.actionlint
    ["pinact"] = Builtins.pinact
    ["ghalint"] = Builtins.ghalint_workflow
    ["zizmor"] = Builtins.zizmor

    // Markdown / TOML
    ["markdown"] = Builtins.rumdl
    ["toml"] = Builtins.tombi

    // mise.toml itself
    ["mise"] = Builtins.mise

    // Python - run via this project's own uv-managed tools, not PATH binaries
    ["ruff"] = (Builtins.ruff) {
        check = "uv run ruff check --force-exclude {{ files }}"
        fix = "uv run ruff check --force-exclude --fix {{ files }}"
    }
    ["ruff-format"] = (Builtins.ruff_format) {
        check_diff = "uv run ruff format --quiet --force-exclude --diff {{ files }}"
        fix = "uv run ruff format --quiet --force-exclude {{ files }}"
    }
    ["ty"] = (Builtins.ty) {
        check = "uv run ty check {{ files }}"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = linters
    }
    ["pre-push"] {
        steps = linters
    }
    ["check"] {
        steps = linters
    }
    ["fix"] {
        fix = true
        steps = linters
    }
    // Enforces Conventional Commits, since release.yml's auto-tagging
    // depends on commit messages following that format.
    ["commit-msg"] {
        steps {
            ["conventional-commit"] = Builtins.check_conventional_commit
        }
    }
}
